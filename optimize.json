{
  "optimization-strategy": "QuantConnect.Optimizer.Strategies.EulerSearchOptimizationStrategy",
  "optimization-strategy-settings": {
    "default-segment-amount": 10
  },
  "optimization-criterion": {
    "target": "TotalPerformance.PortfolioStatistics.CompoundingAnnualReturn",
    "extremum": "max"
  },
  "constraints": [
    {
      "target": "TotalPerformance.PortfolioStatistics.Drawdown",
      "operator": "less",
      "target-value": "0.03"
    }
  ],
  "parameters": [
    {"name": "long_orb_minutes", "min": 5, "max": 30, "step": 5},
    {"name": "long_atr_base_mult", "min": 1.0, "max": 3.0, "step": 0.25},
    {"name": "long_atr_tier1_mult", "min": 0.5, "max": 1.5, "step": 0.25},
    {"name": "long_atr_tier2_mult", "min": 0.2, "max": 0.75, "step": 0.05},
    {"name": "long_atr_profit_tier1", "min": 1.0, "max": 4.0, "step": 0.5},
    {"name": "long_atr_profit_tier2", "min": 2.0, "max": 6.0, "step": 0.5},
    {"name": "long_breakout_offset", "min": 0.01, "max": 0.10, "step": 0.01},
    {"name": "short_orb_minutes", "min": 5, "max": 30, "step": 5},
    {"name": "short_atr_base_mult", "min": 1.0, "max": 3.0, "step": 0.25},
    {"name": "short_atr_tier1_mult", "min": 0.5, "max": 1.5, "step": 0.25},
    {"name": "short_atr_tier2_mult", "min": 0.2, "max": 0.75, "step": 0.05},
    {"name": "short_atr_profit_tier1", "min": 1.0, "max": 4.0, "step": 0.5},
    {"name": "short_atr_profit_tier2", "min": 2.0, "max": 6.0, "step": 0.5},
    {"name": "short_breakout_offset", "min": 0.01, "max": 0.10, "step": 0.01},
    {"name": "gap_filter_pct", "min": 0.02, "max": 0.05, "step": 0.005},
    {"name": "max_trades_per_direction", "min": 1, "max": 5, "step": 1}
  ],
  "node": {"nodes": 6, "cores": 4, "memory": 12}
}

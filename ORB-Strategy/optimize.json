{
    "algorithm-language": "Python",
    "parameters": {
        "orb_minutes": {
            "min": 5,
            "max": 30,
            "step": 5
        },
        "atr_base_mult": {
            "min": 1.0,
            "max": 3.0,
            "step": 0.25
        },
        "atr_tier1_mult": {
            "min": 0.5,
            "max": 1.25,
            "step": 0.25
        },
        "atr_tier2_mult": {
            "min": 0.2,
            "max": 0.6,
            "step": 0.1
        },
        "atr_profit_tier1": {
            "min": 1.0,
            "max": 5.0,
            "step": 1.0
        },
        "atr_profit_tier2": {
            "min": 3.0,
            "max": 8.0,
            "step": 1.0
        },
        "gap_filter_pct": {
            "min": 0.01,
            "max": 0.05,
            "step": 0.01
        },
        "breakout_offset": {
            "min": 0.0,
            "max": 0.20,
            "step": 0.05
        },
        "max_trades_per_direction": {
            "min": 1,
            "max": 5,
            "step": 1
        }
    },
    "constraints": [
        "atr_profit_tier2 > atr_profit_tier1",
        "atr_tier1_mult > atr_tier2_mult"
    ],
    "optimization-strategy": "QuantConnect.Optimizer.Strategies.EulerSearchOptimizationStrategy",
    "optimization-strategy-settings": {
        "default-segment-amount": 10
    },
    "optimization-criterion": {
        "target": "Statistics.SCORE",
        "extremum": "max"
    }
}
